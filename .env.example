# ─────────────────────────────────────────────────────────────────
# DATABASE (Neon PostgreSQL)
# ─────────────────────────────────────────────────────────────────

# Pooled connection — pakai ini untuk queries normal (dengan pgbouncer)
# Tambahkan &pgbouncer=true di akhir URL dari Neon dashboard
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxx-pooler.c-2.ap-southeast-1.aws.neon.tech/skripsiku?sslmode=require&channel_binding=require&pgbouncer=true"

# Direct connection — pakai ini untuk migrations (prisma migrate deploy)
# Sama dengan DATABASE_URL tapi TANPA -pooler di hostname dan TANPA &pgbouncer=true
DIRECT_URL="postgresql://neondb_owner:PASSWORD@ep-xxx.c-2.ap-southeast-1.aws.neon.tech/skripsiku?sslmode=require&channel_binding=require"

# ─────────────────────────────────────────────────────────────────
# AUTH (Auth.js / NextAuth v5)
# ─────────────────────────────────────────────────────────────────

# Generate dengan: openssl rand -base64 32
AUTH_SECRET=""

# URL deployment kamu di Vercel (tanpa trailing slash)
# Contoh: https://lexica-utbk.vercel.app
NEXTAUTH_URL=""

# ─────────────────────────────────────────────────────────────────
# AI
# ─────────────────────────────────────────────────────────────────

# Groq API key untuk AI Tutor
GROQ_API_KEY=""

# ─────────────────────────────────────────────────────────────────
# CATATAN DEPLOYMENT
# ─────────────────────────────────────────────────────────────────
# 1. Copy file ini jadi .env untuk development lokal
# 2. Masukkan semua variable di atas ke Vercel Dashboard:
#    Project → Settings → Environment Variables
# 3. Jalankan migration di production:
#    npx prisma migrate deploy
#    (gunakan DIRECT_URL, bukan DATABASE_URL)
